rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/usuarios/$(request.auth.uid);
    }

    function hasUserProfile() {
      return signedIn() && exists(userPath());
    }

    function userProfile() {
      return get(userPath()).data;
    }

    function activeUser() {
      return hasUserProfile() && userProfile().activo != false;
    }

    function isAdmin() {
      return activeUser() && userProfile().rol == 'admin';
    }

    function publicCatalogDoc(tabla) {
      return tabla in [
        'productos',
        'categoriasData',
        'configCreditoGlobal'
      ];
    }

    match /usuarios/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();

      // Compatibilidad con la app actual: al crear usuarios desde el cliente,
      // Firebase Auth cambia la sesion al usuario recien creado y ese usuario
      // guarda su propio perfil en /usuarios/{uid}.
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'nombre',
          'rol',
          'email',
          'creadoEn',
          'activo',
          'vendedorId',
          'vendedorNombre'
        ])
        && request.resource.data.rol == 'vendedor'
        && request.resource.data.activo is bool;

      allow update, delete: if isAdmin();
    }

    match /posData/{tabla} {
      // Catalogo publico. Ojo: Firestore no filtra campos por regla; estos
      // documentos deben contener solo datos que aceptas exponer al cliente.
      allow get: if publicCatalogDoc(tabla) || activeUser();

      // La app privada usa StorageService.syncAll(), que lista toda la coleccion.
      allow list: if activeUser();

      // Admin y vendedor activos pueden sincronizar datos operativos.
      // Los permisos finos por rol se aplican hoy en la UI.
      allow create, update: if activeUser();
      allow delete: if isAdmin();
    }

    match /pushTokens/{tokenId} {
      allow create, update: if activeUser()
        && request.resource.data.rol == userProfile().rol
        && request.resource.data.token is string;
      allow get, list, delete: if isAdmin();
    }

    match /pushOutbox/{pushId} {
      allow create: if activeUser()
        && request.resource.data.type == 'autorizacion_boveda'
        && request.resource.data.status == 'pending';
      allow get, list, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
